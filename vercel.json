{\n  "version": 2,\n  "builds": [\n    {\n      "src": "server.js",\n      "use": "@vercel/node"\n    },\n    {\n      "src": "public/**",\n      "use": "@vercel/static"\n    }\n  ],\n  "routes": [\n    {\n      "src": "/api/(.*)",\n      "dest": "server.js"\n    },\n    {\n      "src": "/(.*)",\n      "dest": "public/$1"\n    }\n  ],\n  "env": {\n    "GEMINI_API_KEY": "@GEMINI_API_KEY"\n  }\n}